{
    "name": "travel-log",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "concurrently \"nuxt dev\" \"pnpm db:local\"",
        "dev:all": "concurrently \"nuxt dev\" \"pnpm db:local\" \"drizzle-kit studio\"",
        "build": "nuxt build",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",

        "db:local": "turso dev --db-file local.db",
        "db:reset": "rm -f local.db*",
        "db:push": "drizzle-kit push",
        "db:gen": "drizzle-kit generate",
        "db:mg": "drizzle-kit migrate",
        "db:std": "drizzle-kit studio",
        "db:auth:gen": "pnpm dlx auth@latest generate --config ./server/utils/auth.ts --output ./server/db/schema/auth-gen.ts",

        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prepare": "husky"
    },
    "dependencies": {
        "@libsql/client": "^0.17.3",
        "@nuxt/eslint": "1.15.2",
        "@nuxt/ui": "^4.7.1",
        "better-auth": "^1.6.10",
        "concurrently": "^9.2.1",
        "drizzle-orm": "^0.45.2",
        "nuxt": "^4.4.4",
        "tailwindcss": "^4.3.0",
        "vue": "^3.5.34",
        "vue-router": "^5.0.6",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^8.2.0",
        "@iconify-json/tabler": "^1.2.35",
        "@types/node": "^25.6.2",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.3.0",
        "eslint-plugin-better-tailwindcss": "^4.5.0",
        "eslint-plugin-format": "^2.0.1",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.4"
    },
    "lint-staged": {
        "*": "eslint --fix"
    }
}
